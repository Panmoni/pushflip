{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Type-safety (strict family) */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    /*
     * `erasableSyntaxOnly` is intentionally OFF: @pushflip/client (workspace
     * dep) is consumed in source form via `main: "src/index.ts"` and uses
     * `const enum` for instruction discriminators. esbuild/Vite handle the
     * non-erasable syntax fine; the other strict-family flags above still
     * cover the real safety surface.
     */

    /* Path aliases (paths are relative to this tsconfig in TS 6+) */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
