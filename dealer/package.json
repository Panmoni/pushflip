{
  "name": "@pushflip/dealer",
  "description": "Workspace-internal ZK dealer for the pushflip program. Consumed in source form via tsx; not intended for publishing. Run `pnpm build` first if you need a compiled artifact under dist/.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "start": "npx tsx src/index.ts",
    "test": "npx tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@solana/kit": "^2.1.0",
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/snarkjs": "^0.7.8",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
